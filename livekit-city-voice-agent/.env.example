# LiveKit Configuration (required for Docker Compose)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LiveKit URL for browser (client-side) - must use localhost for Mac!
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# OpenAI API Key (required for knowledge base embeddings and LLM)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs Configuration (required for German text-to-speech)
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVEN_API_KEY=

# ElevenLabs Voice ID (optional, defaults to German voice)
# Browse voices at: https://elevenlabs.io/app/voice-library
ELEVEN_VOICE_ID=hpp4J3VqNfWAUOO0d1Us

# Agent Display Name (optional) - change to your city/brand name
AGENT_NAME=City Assistant

# PostgreSQL Password (optional, defaults shown)
POSTGRES_PASSWORD=rag_pass_dev
