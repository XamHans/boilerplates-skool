{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "job-search-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-18",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "JobSearchAgent",
        "class_name": "JobSearchAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["JobSearchAgent"]
    }
  ],
  "triggers": {
    // Every Monday at 06:00 UTC
    "crons": ["0 6 * * 1"]
  },
  "observability": {
    "enabled": true
  }
}
